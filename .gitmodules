[submodule ".registry"]
	path = .registry
	url = https://github.com/andrjohns/andrjohns.r-universe.dev
	branch = HEAD
[submodule "QuickJSR"]
	path = QuickJSR
	url = https://github.com/andrjohns/QuickJSR
[submodule "StanEstimators"]
	path = StanEstimators
	url = https://github.com/andrjohns/StanEstimators
[submodule "StanHeaders"]
	path = StanHeaders
	url = https://github.com/stan-dev/rstan
	branch = v2.39.0
	subdir = StanHeaders
[submodule "boostmath"]
	path = boostmath
	url = https://github.com/andrjohns/boostmath
[submodule "jsutils"]
	path = jsutils
	url = https://github.com/andrjohns/jsutils
[submodule "rstan"]
	path = rstan
	url = https://github.com/stan-dev/rstan
	branch = v2.39.0
	subdir = rstan/rstan
